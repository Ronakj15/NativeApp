{
  "appId": "com.viso.attendance",
  "appName": "Viso",
  "webDir": "out",
  "server": {
    "androidScheme": "https"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#0b0e17",
      "showSpinner": false,
      "launchAutoHide": true,
      "androidScaleType": "CENTER_CROP"
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#0b0e17"
    },
    "PushNotifications": {
      "presentationOptions": ["badge", "sound", "alert"]
    },
    "BluetoothLe": {
      "displayStrings": {
        "scanning": "Scanning for attendance beacons...",
        "cancel": "Cancel",
        "availableDevices": "Available Beacons",
        "noDeviceFound": "No beacon found"
      }
    }
  }
}
